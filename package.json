{
	"name": "azure-function-boilerplate",
	"version": "0.0.1",
	"description": "azure-function-boilerplate",
	"type": "module",
	"scripts": {
		"build": "tsc",
		"watch": "tsc -w",
		"clean": "rimraf dist",
		"prestart": "pnpm run clean && pnpm run build",
		"start": "func start",
		"test": "echo \"No tests yet...\"",
		"dev": "concurrently \"pnpm run watch\" \"pnpm run start\"",
		"lint-staged": "lint-staged --verbose",
		"lint": "eslint ./src/**/*.{js,jsx,ts,tsx}",
		"prepare": "if [ -d node_modules/husky ]; then husky; fi"
	},
	"dependencies": {
		"@azure/functions": "^4.11.2"
	},
	"devDependencies": {
		"@innovixx/eslint-config": "^3.0.12",
		"@types/node": "^25.4.0",
		"concurrently": "^9.2.1",
		"eslint": "9.39.4",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"rimraf": "^6.1.3",
		"typescript": "^5.9.3"
	},
	"lint-staged": {
		"**/*.{js,ts,jsx,tsx}": [
			"eslint",
			"bash -c tsc"
		]
	},
	"main": "dist/src/functions/**/*.js"
}